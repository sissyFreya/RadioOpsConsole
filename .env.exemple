# ICECAST_PUBLIC_BASE=http://149.202.41.3:8000
ICECAST_PUBLIC_BASE=http://localhost:8000

# ===== Frontend =====
VITE_API_BASE=http://localhost:8000
VITE_AGENT_WS_BASE=ws://localhost:9000
