# ===== Backend =====
POSTGRES_USER=radioops
POSTGRES_PASSWORD=radioops
POSTGRES_DB=radioops
POSTGRES_HOST=db
POSTGRES_PORT=5432

JWT_SECRET=change-me-super-secret
JWT_ACCESS_MINUTES=60

BOOTSTRAP_ADMIN_EMAIL=admin@local.test
BOOTSTRAP_ADMIN_PASSWORD=admin

# ===== Agent (docker-compose demo agent) =====
AGENT_URL=http://agent:9000

# ===== Icecast public URL (used by the frontend to build stream links) =====
